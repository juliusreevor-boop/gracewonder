    <style>
        /* CSS: This is the design part (Option A + Playful tweaks) */
        
        :root {
            --primary-blue: #0A66C2; /* A strong, loyal, deep blue */
            --accent-blue: #E0F2FE;  /* Very light, airy pastel blue */
            --background-base: #FFFFFF; /* Pure white for minimalism */
            --champagne-gold: #FBF7F1; /* Subtle, warm backdrop for sentimental text */
            --text-dark: #1F2937;  /* Soft black for readability */
