        a { text-decoration: none; transition: color 0.3s ease; color: inherit; }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        /* --- 1. Hero Header & Countdown --- */
        #hero {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background-color: var(--accent-blue);
            position: relative;
            padding: 2rem;
            border-bottom: 5px solid var(--primary-blue);
        }

        #hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23000' fill-opacity='0.03' fill-rule='evenodd'%3E%3Ccircle cx='3' cy='3' r='3'/%3E%3Ccircle cx='13' cy='13' r='3'/%3E%3C/g%3E%3C/svg%3E");
            opacity: 0.5;
        }

        .hero-content {
            z-index: 10;
            background-color: rgba(255, 255, 255, 0.8);
            padding: 4rem 2rem;
            border-radius: 20px;
            backdrop-filter: blur(5px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        }

        .hero-title {
            font-size: 3.5rem;
            color: var(--primary-blue);
            margin-bottom: 1rem;
            line-height: 1.2;
        }

        .hero-subtitle {
            font-size: 1.5rem;
            color: var(--text-light);
            margin-bottom: 2.5rem;
            font-weight: 300;
        }

        /* The Countdown Timer */
        #countdown {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            font-weight: 600;
        }

        .countdown-segment {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .countdown-number {
            font-size: 3rem;
            color: var(--primary-blue);
            background: rgba(255, 255, 255, 0.9);
            padding: 1rem 1.5rem;
            border-radius: 12px;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
            font-family: monospace; /* Keep numbers aligned */
        }

        .countdown-label {
            font-size: 0.8rem;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 0.5rem;
        }

        /* --- 2. The Narrative Section --- */
        #story {
            padding: 8rem 0;
            background-color: var(--champagne-gold);
            text-align: center;
        }

        .story-block {
            margin-bottom: 4rem;
        }

        .story-title {
            font-size: 2.5rem;
            color: var(--text-dark);
            margin-bottom: 1.5rem;
        }

        .streak-mention {
            font-weight: 600;
            font-style: italic;
            color: var(--tiktok-pink);
            display: block;
            margin-bottom: 2rem;
        }

        .story-text {
            font-size: 1.125rem;
            color: var(--text-light);
            max-width: 800px;
            margin: 0 auto;
            text-align: left; /* Keep long text readable */
            padding: 0 1rem;
        }

        .story-highlight {
            font-weight: 600;
            color: var(--primary-blue);
        }

        /* --- 3. The Masonry Gallery --- */
        #moments {
            padding: 8rem 0;
            background-color: var(--background-base);
        }

        .section-header {
            text-align: center;
            margin-bottom: 5rem;
        }

        .section-title {
            font-size: 2.8rem;
            color: var(--primary-blue);
        }

        /* Minimalist Gallery Structure */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            grid-gap: 15px;
            grid-auto-flow: dense;
        }

        .grid-item {
            position: relative;
            overflow: hidden;
            border-radius: 12px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .grid-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.07);
        }

        .grid-item img, .grid-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Different aspect ratios to make it interesting */
        .grid-item.portrait { grid-row: span 2; }
        .grid-item.wide { grid-column: span 2; }

        .overlay {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.9) 100%);
            padding: 1.5rem;
            transform: translateY(100%);
            transition: transform 0.3s ease;
        }

        .grid-item:hover .overlay {
            transform: translateY(0%);
        }

        .caption-text {
            font-size: 0.95rem;
            color: var(--text-dark);
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .caption-metadata {
            font-size: 0.8rem;
            color: var(--text-light);
        }

        /* --- 4. Special Memories / Sentimental Block --- */
        #spotlight {
            padding: 8rem 0;
            background-color: var(--accent-blue);
            color: var(--background-base);
            position: relative;
        }

        #spotlight::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 100px;
            background: var(--background-base);
            clip-path: polygon(0 100%, 100% 0%, 100% 100%, 0% 100%);
        }

        .spotlight-content {
            background-color: var(--champagne-gold);
            color: var(--text-dark);
            padding: 4rem;
            border-radius: 20px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.08);
            max-width: 900px;
            margin: 0 auto;
            position: relative;
            z-index: 5;
        }

        .spotlight-title {
            font-size: 2.2rem;
            color: var(--primary-blue);
            margin-bottom: 2rem;
            text-align: center;
        }

        .memory-card {
            margin-bottom: 2rem;
            padding-left: 2rem;
            border-left: 4px solid var(--primary-blue);
        }

        .memory-highlight {
            font-weight: 600;
            color: var(--primary-blue);
            font-style: italic;
        }

        /* --- 5. The Birthday Message (Sentimental) --- */
        #message {
            padding: 8rem 0;
            background-color: var(--background-base);
        }

        .final-message {
            font-size: 1.25rem;
            color: var(--text-dark);
            max-width: 850px;
            margin: 0 auto;
            white-space: pre-line; /* respects the line breaks in your message */
            padding: 0 1rem;
        }

        .heart-breaker {
            display: block;
            text-align: center;
            font-size: 2rem;
            color: var(--primary-blue);
            margin: 3rem 0;
        }

        /* --- Footer --- */
        footer {
            background-color: var(--text-dark);
            color: var(--background-base);
            text-align: center;
            padding: 3rem;
            border-top: 5px solid var(--primary-blue);
        }

        .footer-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--background-base);
            margin-bottom: 1rem;
        }

        .footer-note {
            font-size: 0.9rem;
            color: var(--text-light);
        }

        /* Mobile Adjustments (Responsive Design) */
        @media (max-width: 768px) {
            .hero-title { font-size: 2.5rem; }
            #countdown { gap: 0.5rem; }
            .countdown-number { font-size: 2rem; padding: 0.75rem; }
            .grid-container { grid-template-columns: 1fr; }
            .grid-item.wide { grid-column: span 1; }
            .story-text, .final-message { font-size: 1rem; }
            .spotlight-content { padding: 2rem; }
        }
    </style>
</head>
